3(d)#Electricity Bill Generator
final_amount <- function(amount){
  if(amount >= 5000){
    discount <- amount * 0.20
  } else if(amount >= 2000){
    discount <- amount * 0.10
  } else {
    discount <- 0
  }
  return(amount - discount)
}
final_amount(1500)
